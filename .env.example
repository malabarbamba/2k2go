# Frontend boot can read either runtime-config.json or Vite env vars.
# Copy these into a local .env only if you do not want to use public/runtime-config.json.
# Never expose Supabase service role keys in frontend env vars.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Edge Functions / server-side
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# Email defaults
AUTH_EMAIL_FROM_NAME=2k2go
AUTH_EMAIL_FROM_EMAIL=arabeurgence@gmail.com
APP_NON_REPLY_EMAIL=arabeurgence@gmail.com
AUTH_EMAIL_SUPPORT=arabeurgence@gmail.com
APP_SUPPORT_EMAIL=arabeurgence@gmail.com

# Public app URLs
SITE_URL=https://2k2go.github.io
AUTH_EMAIL_SITE_URL=https://2k2go.github.io
REVIEW_REMINDERS_APP_URL=https://2k2go.github.io/app

# CORS
CORS_ALLOWED_ORIGINS=https://*.github.io,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS_STRICT=true
